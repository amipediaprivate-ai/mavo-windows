{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mavo",
  "version": "0.1.0",
  "identifier": "ai.amipedia.mavo",
  "build": {
    "beforeDevCommand": "pnpm.cmd dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm.cmd build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "label": "main",
      "title": "Mavo",
      "width": 1440,
      "height": 900,
      "minWidth": 1040,
      "minHeight": 680,
      "resizable": true,
      "fullscreen": false,
      "center": true
    }],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/thumbnails/**"]
      }
    }
  },
  "bundle": { "active": false, "targets": "all" }
}
